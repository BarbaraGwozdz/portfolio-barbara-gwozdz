<!DOCTYPE html>
<html lang="pl" data-lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Barbara Gwóźdź — HR & People Analytics</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#F2EAE0;
  --bg2:#E9E1D7;
  --bg3:#FDFAF5;
  --dark:#18120F;
  --bx:#7B2C3C; /* Bordowy */
  --bxh:#9C3E50;
  --bxp:#F0DDE2;
  --t:#1A1410;
  --tm:#7A6A5E;
  --br:#C5BAB0;
  --ff:'Syne',sans-serif;
  --fb:'DM Sans',sans-serif;
}

/* Zmieniony DARK MODE - Bordowy z białymi i czarnymi detalami */
[data-dark]{
  --bg:#4A1A24; /* Ciemny bordowy bazowy */
  --bg2:#38131B; /* Nieco ciemniejszy bordowy */
  --bg3:#5C212E; /* Jaśniejszy bordowy na karty */
  --dark:#000000; /* Czarne tła w stopce/kontakcie */
  --bx:#FFFFFF; /* Białe główne detale */
  --bxh:#E8D8DC; 
  --bxp:rgba(0,0,0,0.4); /* Czarne półprzezroczyste tła detali */
  --t:#FFFFFF; /* Biały tekst główny */
  --tm:#D1C5C7; /* Zgaszony biały tekst pomocniczy */
  --br:rgba(255,255,255,0.2); /* Białe ramki */
}

html{scroll-behavior:smooth;}
body{font-family:var(--fb);background:var(--bg);color:var(--t);font-size:16px;overflow-x:hidden;transition:background .3s,color .3s;}
a{color:inherit;text-decoration:none;}

/* NAV */
nav{
  position:sticky;top:0;z-index:100;
  background:rgba(242,234,224,.95);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--br);
  height:60px;padding:0 52px;
  display:flex;justify-content:space-between;align-items:center;
  transition:background .3s,border-color .3s;
}
[data-dark] nav{background:rgba(74,26,36,.95);}
.nav-l{display:flex;align-items:center;gap:32px;}
.nav-logo{font-family:var(--ff);font-weight:800;font-size:14px;letter-spacing:.08em;color:var(--bx);}
.nav-links{display:flex;gap:26px;}
.nav-links a{font-size:11px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--tm);transition:color .2s;}
.nav-links a:hover{color:var(--bx);}
.nav-r{display:flex;align-items:center;gap:12px;}
.nav-btn{
  font-size:11px;font-weight:600;letter-spacing:.06em;
  padding:7px 16px;border-radius:100px;cursor:pointer;transition:all .2s;border:none;
  font-family:var(--fb);
}
.btn-dl{background:var(--bx);color:#fff;}
[data-dark] .btn-dl {background: #000000; color: #FFFFFF; border: 1px solid #FFFFFF;} 
.btn-dl:hover{background:var(--bxh);}
.btn-lang{background:transparent;color:var(--tm);border:1px solid var(--br);}
.btn-lang:hover{color:var(--bx);border-color:var(--bx);}
.btn-dark{
  width:36px;height:36px;border-radius:50%;
  background:transparent;border:1px solid var(--br);
  color:var(--tm);cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  font-size:15px;transition:all .2s;
}
.btn-dark:hover{border-color:var(--bx);color:var(--bx);}

/* HERO */
#hero{
  min-height:91vh;padding:0 52px;
  display:grid;grid-template-columns:1fr auto;
  align-items:center;gap:48px;
  border-bottom:1px solid var(--br);
  position:relative;overflow:hidden;
}
.hero-l{padding:72px 0; z-index:2;}
.h-eye{
  font-size:11px;letter-spacing:.16em;text-transform:uppercase;
  color:var(--bx);margin-bottom:24px;
  display:flex;align-items:center;gap:14px;
  animation:fadeUp .7s .1s both;
}
.h-eye::after{content:'';width:40px;height:1px;background:var(--bx);}
.h-name{
  font-family:var(--ff);font-weight:800;
  font-size:clamp(56px,10vw,108px);line-height:.9;
  letter-spacing:-.03em;margin-bottom:40px;
  animation:fadeUp .7s .2s both;
}
.h-name .ax{color:var(--bx);}
.h-body{animation:fadeUp .7s .32s both;}
.h-desc{
  font-size:16px;line-height:1.85;color:var(--tm);
  border-left:2.5px solid var(--bx);padding-left:20px;
  max-width:420px;margin-bottom:28px;
}
.h-kw{cursor:default;transition:color .2s;position:relative;display:inline-block;}
.h-kw:hover{color:var(--bx);}
.kw-tip{
  position:absolute;top:-28px;left:50%;transform:translateX(-50%);
  font-size:20px;pointer-events:none;
  opacity:0;transition:opacity .2s,transform .2s;
  white-space:nowrap;
}
.h-kw:hover .kw-tip{opacity:1;transform:translateX(-50%) translateY(-4px);}

.h-actions{display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:32px;}
.h-cta{
  background:var(--bx);color:#fff;
  font-size:13px;font-weight:600;font-family:var(--fb);
  padding:12px 24px;border-radius:100px;border:none;cursor:pointer;
  display:flex;align-items:center;gap:8px;
  transition:background .2s,transform .2s;
}
[data-dark] .h-cta{background: #000000; color: #FFFFFF; border: 1px solid #FFFFFF;}
.h-cta:hover{background:var(--bxh);transform:translateY(-1px);}
.h-cta-ghost{
  background:transparent;color:var(--t);
  font-size:13px;font-weight:500;font-family:var(--fb);
  padding:12px 20px;border-radius:100px;
  border:1px solid var(--br);cursor:pointer;
  transition:border-color .2s,color .2s;
}
.h-cta-ghost:hover{border-color:var(--bx);color:var(--bx);}
.h-pills{display:flex;flex-wrap:wrap;gap:7px;}
.pill{
  background:var(--bxp);color:var(--bx);
  font-size:11px;font-weight:500;letter-spacing:.04em;
  padding:6px 14px;border-radius:100px;
  border:1px solid var(--br);white-space:nowrap;
  transition:background .3s;
}
[data-dark] .pill{background: #000000; color: #FFFFFF; border-color: #FFFFFF;}

/* Photo */
.hero-r{
  display:flex;align-items:center; /* Wyśrodkowane pionowo względem lewego panelu */
  justify-content:center;
  height:100%;padding-bottom:0;position:relative;z-index:2;
}
.photo-wrap{
  width:280px;height:400px;
  border-radius:140px 140px 0 0;
  background:var(--bg2);
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;border:3px solid var(--bxp);
  position:relative;flex-shrink:0;
}
[data-dark] .photo-wrap{border-color:#000000;}
.photo-wrap img{width:100%;height:100%;object-fit:cover;object-position:center top;}
.photo-placeholder-text{
  font-family:var(--ff);
  color:var(--tm);
  font-weight:700;
  font-size:14px;
  text-align:center;
  padding:20px;
  border:2px dashed var(--bx);
  border-radius:100px;
}

/* SECTION */
section{padding:88px 52px; position:relative; z-index:2;}
.sec-inner{max-width:960px;margin:0 auto;}
#about{background:var(--bg2);border-bottom:1px solid var(--br);}
#experience{background:var(--bg);border-bottom:1px solid var(--br);}
#projects{background:var(--bg2);border-bottom:1px solid var(--br);}
#skills{background:var(--bg);border-bottom:1px solid var(--br);}
#contact{background:var(--dark);border-bottom:1px solid rgba(255,255,255,.07);}
#contact .sec-inner{color:var(--bg);}
[data-dark] #contact .sec-inner{color:var(--t);}
.sec-head{margin-bottom:52px;display:flex;align-items:baseline;gap:20px;flex-wrap:wrap;}
.sec-n{
  font-family:var(--ff);font-weight:800;font-size:11px;
  color:var(--bx);letter-spacing:.14em;
  display:flex;align-items:center;gap:8px;flex-shrink:0;
}
.sec-n::after{content:'';display:inline-block;width:32px;height:1px;background:var(--bx);}
.sec-t{font-family:var(--ff);font-weight:700;font-size:clamp(28px,4vw,44px);letter-spacing:-.02em;line-height:1.1;}

/* ABOUT */
.about-g{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;}
.about-txt{font-size:15.5px;line-height:1.85;color:var(--tm);}
.about-txt p+p{margin-top:14px;}
.chips{margin-top:26px;display:flex;flex-wrap:wrap;gap:8px;}
.chip{background:var(--bg);border:1px solid var(--br);border-radius:100px;font-size:12px;padding:6px 14px;color:var(--t);}
[data-dark] .chip{background:#000000; border-color:#FFFFFF;}

/* OSOBOWOŚĆ W ABOUT */
.personality-cards{display:flex;flex-direction:column;gap:16px;}
.p-card{
  background:var(--bg3);border:1px solid var(--br);border-radius:8px;
  padding:24px;border-left:4px solid var(--bx);
  transition:transform .2s, box-shadow .2s;
}
[data-dark] .p-card{background:#000000;}
.p-card:hover{transform:translateY(-2px);box-shadow:4px 4px 0 var(--bxp);}
.p-cat{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--bx);font-weight:700;margin-bottom:6px;}
.p-title{font-family:var(--ff);font-weight:700;font-size:22px;color:var(--t);margin-bottom:8px;}
.p-desc{font-size:13px;color:var(--tm);line-height:1.5;}

/* TIMELINE */
.tls{position:relative;padding-left:30px;max-width:720px;}
.tls::before{content:'';position:absolute;left:6px;top:12px;bottom:12px;width:1px;background:var(--br);}
.tl{position:relative;margin-bottom:44px;}
.tl:last-child{margin-bottom:0;}
.tl::before{
  content:'';position:absolute;left:-27px;top:8px;
  width:10px;height:10px;border-radius:50%;
  background:var(--bx);border:2px solid var(--bg);
  box-shadow:0 0 0 3px var(--bxp);
}
[data-dark] .tl::before{box-shadow:0 0 0 3px #000000;}
.tl-d{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--bx);font-weight:600;margin-bottom:5px;}
.tl-r{font-family:var(--ff);font-weight:700;font-size:19px;margin-bottom:3px;}
.tl-o{font-size:13px;color:var(--tm);font-weight:500;margin-bottom:10px;display:flex;align-items:center;gap:6px;}
.tl-o::before{content:'@';color:var(--bx);font-size:11px;font-weight:700;}
.tl-p{font-size:14px;color:var(--tm);line-height:1.75;}

/* PROJECTS */
.pf-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:32px;}
.pf-tab{
  font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;
  padding:7px 16px;border-radius:100px;cursor:pointer;border:1px solid var(--br);
  background:transparent;color:var(--tm);transition:all .2s;font-family:var(--fb);
}
.pf-tab:hover,.pf-tab.active{background:var(--bx);color:#fff;border-color:var(--bx);}
[data-dark] .pf-tab:hover, [data-dark] .pf-tab.active{background:#000000; color:#FFFFFF; border-color:#FFFFFF;}
.pg{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:18px;}
.pc{
  background:var(--bg3);border:1px solid var(--br);border-radius:4px;
  padding:26px 22px;position:relative;overflow:hidden;
  transition:border-color .25s,transform .2s,box-shadow .2s;
  cursor:pointer;
}
.pc:hover{border-color:var(--bx);box-shadow:4px 4px 0 var(--bxp);transform:translateY(-2px);}
.pc[data-cat]{display:block;}
.pc.hidden{display:none;}
.pc-bar{position:absolute;top:0;left:0;right:0;height:3px;background:var(--bx);}
.pc-cat{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--bx);font-weight:700;margin-bottom:10px;}
.pc-title{font-family:var(--ff);font-weight:700;font-size:17px;line-height:1.2;margin-bottom:10px;}
.pc-desc{font-size:13px;color:var(--tm);line-height:1.7;margin-bottom:18px;}
.pc-bot{display:flex;justify-content:space-between;align-items:flex-end;gap:8px;flex-wrap:wrap;}
.pc-tools{display:flex;flex-wrap:wrap;gap:5px;}
.pt{font-size:10px;padding:4px 10px;background:var(--bg2);border:1px solid var(--br);border-radius:100px;color:var(--tm);}
[data-dark] .pt{background:#000000;}
.badge{font-size:9px;letter-spacing:.06em;padding:4px 10px;border-radius:100px;font-weight:600;white-space:nowrap;}
.b-wip{background:#FEF3C7;color:#92400E;}
.b-plan{background:var(--bxp);color:var(--bx);}
[data-dark] .b-plan{background:#000000; color:#FFFFFF; border:1px solid #FFFFFF;}

/* SKILLS RADAR */
.skills-g{display:grid;grid-template-columns:1fr 1.2fr;gap:60px;align-items:center;}
.chart-wrap{width:100%; max-width:400px; margin:0 auto; aspect-ratio:1/1;}
.skills-lists{display:grid;grid-template-columns:1fr 1fr;gap:32px;}
.sg-t{
  font-family:var(--ff);font-weight:700;font-size:11px;
  letter-spacing:.1em;text-transform:uppercase;color:var(--bx);
  padding-bottom:10px;border-bottom:1.5px solid var(--bx);margin-bottom:14px;
}
.sl{list-style:none;}
.sl li{
  font-size:14px;color:var(--tm);padding:7px 0;
  border-bottom:1px solid var(--br);
  display:flex;align-items:center;gap:8px;line-height:1.4;
}
.sl li::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--bx);flex-shrink:0;}

.cert-box{
  grid-column:1/-1;margin-top:8px;
  background:var(--bxp);border:1px solid var(--br);
  border-radius:4px;padding:18px 22px;
  display:flex;align-items:center;gap:16px;max-width:420px;
}
[data-dark] .cert-box{background:#000000; border-color:rgba(255,255,255,0.2);}
.cert-ico{
  width:44px;height:44px;border-radius:50%;background:var(--bx);color:#fff;
  font-family:var(--ff);font-weight:800;font-size:12px;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
[data-dark] .cert-ico{background:#FFFFFF; color:#000000;}
.cert-nm{font-family:var(--ff);font-weight:700;font-size:15px;}
.cert-sb{font-size:12px;color:var(--bx);margin-top:3px;}

/* CONTACT */
#contact .sec-n{color:rgba(255,255,255,.35);}
#contact .sec-n::after{background:rgba(255,255,255,.2);}
.c-g{display:grid;grid-template-columns:1.3fr 1fr;gap:60px;align-items:start;}
.c-big{
  font-family:var(--ff);font-weight:800;
  font-size:clamp(42px,7vw,80px);line-height:.92;letter-spacing:-.03em;
  color:var(--bg);
}
[data-dark] .c-big{color:var(--t);}
.c-big .ax{color:var(--bxh);}
.c-sub{font-size:14px;color:rgba(255,255,255,.45);margin-top:22px;line-height:1.75;max-width:340px;}
[data-dark] .c-sub{color:var(--tm);}
.c-links{display:flex;flex-direction:column;gap:10px;}
.c-item{
  display:flex;align-items:center;gap:16px;
  padding:14px 18px;border:1px solid rgba(255,255,255,.1);
  border-radius:4px;color:var(--bg);
  background:rgba(255,255,255,.04);
  transition:border-color .2s,transform .2s,background .2s;
}
[data-dark] .c-item{color:var(--t);border-color:rgba(255,255,255,.1); background:#000000;}
.c-item:hover{border-color:var(--bxh);transform:translateX(5px);background:rgba(255,255,255,.1);}
[data-dark] .c-item:hover{border-color:#FFFFFF;}
.c-ico{
  width:36px;height:36px;border-radius:50%;
  background:rgba(255,255,255,.2);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:14px;
}
.c-lbl{font-size:9px;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.4);}
.c-val{font-size:14px;font-weight:500;margin-top:1px;}
footer{
  background:var(--dark);border-top:1px solid rgba(255,255,255,.07);
  padding:20px 52px;display:flex;justify-content:space-between;align-items:center;
  flex-wrap:wrap;gap:10px;color:rgba(255,255,255,.3);font-size:11px;letter-spacing:.04em;
}
footer strong{color:rgba(255,255,255,.7);font-family:var(--ff);font-weight:700;}

/* MODAL */
.modal-ov{
  display:none;position:fixed;inset:0;z-index:200;
  background:rgba(24,18,15,.7);backdrop-filter:blur(8px);
  align-items:center;justify-content:center;padding:20px;
}
.modal-ov.open{display:flex;}
.modal{
  background:var(--bg3);border:1px solid var(--br);border-radius:8px;
  max-width:620px;width:100%;max-height:85vh;overflow-y:auto;
  padding:40px 36px;position:relative;
  animation:fadeUp .35s both;
}
[data-dark] .modal{background:#000000;}
.modal-close{
  position:absolute;top:16px;right:16px;width:32px;height:32px;
  border-radius:50%;border:1px solid var(--br);background:transparent;
  cursor:pointer;font-size:14px;color:var(--tm);display:flex;align-items:center;justify-content:center;
  transition:all .2s;
}
.modal-close:hover{border-color:var(--bx);color:var(--bx);}
.modal-cat{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--bx);font-weight:700;margin-bottom:10px;}
.modal-title{font-family:var(--ff);font-weight:700;font-size:24px;margin-bottom:20px;}
.modal-body{font-size:14.5px;color:var(--tm);line-height:1.8;}
.modal-body h4{font-family:var(--ff);font-weight:700;font-size:14px;color:var(--bx);margin:18px 0 6px;text-transform:uppercase;letter-spacing:.06em;}
.modal-body p+p{margin-top:10px;}

.star-row{display:flex;flex-direction:column;gap:12px;margin-top:14px;}
.star-item{padding:14px 16px;background:var(--bg2);border-radius:4px;border-left:3px solid var(--bx);}
[data-dark] .star-item{background:#38131B;}
.star-label{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--bx);margin-bottom:5px;}

/* WIDŻET ANKIETY */
.survey-widget{
  position:fixed;bottom:20px;right:20px;z-index:150;
  background:var(--bg3);border:1px solid var(--br);
  padding:16px 20px;border-radius:12px;
  box-shadow:0 10px 25px rgba(0,0,0,.1);
  display:flex;flex-direction:column;gap:12px;
  transform:translateY(150%);
  animation:slideInSurvey 1s 2s forwards;
}
[data-dark] .survey-widget{background:#000000; border-color:rgba(255,255,255,0.2);}
.sw-title{font-size:12px;font-weight:700;color:var(--t);text-align:center;}
.sw-emojis{display:flex;justify-content:center;gap:12px;}
.sw-emojis button{
  background:transparent;border:none;font-size:24px;cursor:pointer;
  transition:transform .2s;
}
.sw-emojis button:hover{transform:scale(1.2);}
.sw-thanks{display:none;font-size:13px;color:var(--bx);font-weight:700;text-align:center;padding:10px 0;}

@keyframes slideInSurvey{to{transform:translateY(0);}}
@keyframes fadeUp{from{opacity:0;transform:translateY(22px);}to{opacity:1;transform:translateY(0);}}
.reveal{opacity:0;transform:translateY(20px);transition:opacity .6s,transform .6s;}
.reveal.in{opacity:1;transform:translateY(0);}

[data-lang="en"] .pl{display:none;}
[data-lang="pl"] .en{display:none;}

@media(max-width:720px){
  nav{padding:0 20px;}
  .nav-links,.nav-r .btn-dl{display:none;}
  #hero{grid-template-columns:1fr;padding:60px 20px;}
  .hero-r{display:none;}
  section{padding:60px 20px;}
  .about-g,.c-g,.skills-g{grid-template-columns:1fr;gap:36px;}
  .skills-lists{grid-template-columns:1fr;}
  .survey-widget{left:20px; right:20px; bottom:20px;}
  #goose-tracker{display:none;} /* Gąska schowana na mobile dla lepszego UX */
}

/* =========================================================
   GĄSKA - STYLIZACJE 
   ========================================================= */
#goose-tracker {
    --p: 4px;
    position: absolute;
    top: 50px;
    right: 80px;
    width: calc(12 * var(--p)); 
    height: calc(17 * var(--p)); 
    z-index: 1000;
    cursor: pointer;
    background-color: rgba(0, 0, 0, 0.01); 
}

#goose-body {
    width: var(--p);
    height: var(--p);
    background: transparent;
    
    box-shadow:
        /* CZARNY KONTUR */
        calc(4*var(--p)) calc(1*var(--p)) #1a1a1a, calc(5*var(--p)) calc(1*var(--p)) #1a1a1a, calc(6*var(--p)) calc(1*var(--p)) #1a1a1a,
        calc(3*var(--p)) calc(2*var(--p)) #1a1a1a, calc(7*var(--p)) calc(2*var(--p)) #1a1a1a,
        calc(2*var(--p)) calc(3*var(--p)) #1a1a1a, calc(5*var(--p)) calc(3*var(--p)) #1a1a1a, calc(7*var(--p)) calc(3*var(--p)) #1a1a1a,
        calc(3*var(--p)) calc(4*var(--p)) #1a1a1a, calc(7*var(--p)) calc(4*var(--p)) #1a1a1a,

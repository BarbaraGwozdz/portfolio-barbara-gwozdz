<script>
/* ── DARK MODE ── */
const darkBtn = document.getElementById('darkBtn');
let dark = false;
function toggleDark(){
  dark = !dark;
  document.documentElement.toggleAttribute('data-dark', dark);
  darkBtn.textContent = dark ? '☀' : '☽';
  updateChart();
}

/* ── LANG ── */
let lang = 'pl';
function toggleLang(){
  lang = lang === 'pl' ? 'en' : 'pl';
  document.documentElement.setAttribute('data-lang', lang);
  document.querySelectorAll('.pl').forEach(el => el.style.display = lang === 'pl' ? '' : 'none');
  document.querySelectorAll('.en').forEach(el => el.style.display = lang === 'en' ? '' : 'none');
}

/* ── CV DOWNLOAD ── */
function downloadCV(){ alert('Pobieranie pliku CV (Dodaj właściwy link do PDF).'); }

/* ── PROJECT FILTER ── */
document.querySelectorAll('.pf-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.pf-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const f = btn.dataset.filter;
    document.querySelectorAll('.pc').forEach(pc => {
      if(f === 'all' || pc.dataset.cat === f) pc.classList.remove('hidden');
      else pc.classList.add('hidden');
    });
  });
});

/* ── MODALS ── */
function openModal(id){
  document.getElementById(id).classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal(id){
  document.getElementById(id).classList.remove('open');
  document.body.style.overflow = '';
}

/* ── WYKRES RADAROWY ── */
let radarChart;
function buildChart(){
  const ctx = document.getElementById('radarChart').getContext('2d');
  
  const bx = dark ? '#FFFFFF' : '#7B2C3C'; 
  const bxp = dark ? 'rgba(0,0,0,0.4)' : 'rgba(123,44,60,0.15)';
  const tc = dark ? 'rgba(255,255,255,0.7)' : '#7A6A5E';
  const gridColor = dark ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.08)';

  if(radarChart) radarChart.destroy();
  radarChart = new Chart(ctx, {
    type: 'radar',
    data: {
      labels: ['People Analytics', 'L&D Design', 'HR Knowledge', 'Project Mgmt', 'AI & Tools', 'Communication', 'Data Analysis'],
      datasets: [{
        label: 'Profil Kompetencji',
        data: [75, 78, 85, 70, 65, 90, 60],
        borderColor: bx,
        backgroundColor: bxp,
        borderWidth: 2,
        pointBackgroundColor: bx,
        pointBorderColor: dark ? '#5C212E' : '#F2EAE0',
        pointRadius: 5,
        pointHoverRadius: 7,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: { legend: { display: false } },
      scales: {
        r: {
          min: 0,
          max: 100,
          ticks: { display: false, stepSize: 20 },
          grid: { color: gridColor },
          angleLines: { color: gridColor },
          pointLabels: { color: tc, font: { size: 12, family: 'DM Sans', weight: '500' } }
        }
      }
    }
  });
}
function updateChart(){ if(document.getElementById('radarChart')) buildChart(); }

/* ── SCROLL REVEAL ── */
const obs = new IntersectionObserver(els => {
  els.forEach(el => { if(el.isIntersecting) el.target.classList.add('in'); });
}, {threshold: 0.1});
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

/* ── LICZNIK ODWIEDZIN ── */
function initCounter() {
  let visits = localStorage.getItem('bg_visits') || 0;
  visits++;
  localStorage.setItem('bg_visits', visits);
  document.getElementById('visit-count').innerText = visits;
}

/* ── ANKIETA SATYSFAKCJI ── */
function submitSurvey(emoji) {
  document.getElementById('sw-btns').style.display = 'none';
  document.querySelector('.sw-title').style.display = 'none';
  document.getElementById('sw-thanks').style.display = 'block';
  setTimeout(() => {
    document.getElementById('survey-box').style.transform = 'translateY(150%)';
  }, 3000);
}

/* ── GĄSKA (SKRYPT ZACHOWANIA) ── */
const tracker = document.getElementById('goose-tracker');
const bodyGoose = document.getElementById('goose-body');
let targetY = 50; 
let currentY = 50; 
let isScrolling;

function smoothFollow() {
    currentY += (targetY - currentY) * 0.35; 
    tracker.style.top = currentY + 'px';
    requestAnimationFrame(smoothFollow);
}
smoothFollow();

window.addEventListener('scroll', () => {
    targetY = window.scrollY + 50;
    
    if (!bodyGoose.classList.contains('walking')) {
        bodyGoose.classList.add('walking');
    }

    window.clearTimeout(isScrolling);
    isScrolling = setTimeout(() => {
        bodyGoose.classList.remove('walking'); 
    }, 100);
});

tracker.addEventListener('click', () => {
    bodyGoose.classList.remove('walking');
    bodyGoose.classList.add('jumping');
    tracker.classList.add('honking');

    setTimeout(() => {
        bodyGoose.classList.remove('jumping');
        tracker.classList.remove('honking');
    }, 500);
});

/* ── INIT W ZDARZENIU LOAD ── */
window.addEventListener('load', () => {
  buildChart();
  initCounter();
  document.querySelectorAll('.en').forEach(el => el.style.display = 'none');
});
</script>
